# ==============================================================
#  Atlantic Property Hub Ltd — MTR Gardens, Isheri
#  Hostinger (LiteSpeed/Apache) configuration
#  Clean URLs + security hardening
# ==============================================================

# --- Disable directory browsing & Apache content negotiation ---
Options -Indexes -MultiViews

RewriteEngine On

# --------------------------------------------------------------
#  1. Force HTTPS (redirect all HTTP traffic to HTTPS)
#     Exclude /.well-known/ so ACME/Let's Encrypt SSL issuance
#     and renewal (http-01 challenge over port 80) still works.
# --------------------------------------------------------------
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# --------------------------------------------------------------
#  2. Clean URLs — remove the .html extension
# --------------------------------------------------------------
# 2a. Send /index or /index.html to the site root
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# 2b. Redirect any /page.html request to the clean /page URL (301)
RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 2c. Internally serve the .html file for a clean URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# --------------------------------------------------------------
#  3. Security response headers
# --------------------------------------------------------------
<IfModule mod_headers.c>
  # Only advertise HTTPS-only once served over HTTPS (no preload / subdomains,
  # to avoid affecting a mail or other subdomain that may not be HTTPS yet)
  Header always set Strict-Transport-Security "max-age=31536000" "expr=%{HTTPS} == 'on'"

  # Stop MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Clickjacking protection (legacy + modern)
  Header always set X-Frame-Options "SAMEORIGIN"

  # Limit referrer information leakage
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Disable powerful features this brochure site never uses
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"

  # Content Security Policy — allows only self + Google Fonts (CSS/fonts)
  # and the embedded Google Maps iframe. 'unsafe-inline' style is required
  # for the inline background-image style attributes; scripts stay strict.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; frame-src https://www.google.com; connect-src 'self'; form-action 'self' mailto:; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; upgrade-insecure-requests"

  # Do not leak the server/tech stack
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# --------------------------------------------------------------
#  4. Block access to hidden/sensitive files
# --------------------------------------------------------------
# Dotfiles (.htaccess, .git, .env, etc.)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Deny the internal image manifest and any stray config files
<FilesMatch "\.(json|yml|yaml|md|log|bak|ini)$">
  Require all denied
</FilesMatch>

# --------------------------------------------------------------
#  5. Long-lived caching for static assets (perf, no security impact)
# --------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg      "access plus 1 year"
  ExpiresByType image/png       "access plus 1 year"
  ExpiresByType image/x-icon    "access plus 1 year"
  ExpiresByType text/css        "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html       "access plus 1 hour"
</IfModule>

# --------------------------------------------------------------
#  6. Custom error document (falls back to home on 404)
# --------------------------------------------------------------
ErrorDocument 404 /index.html
